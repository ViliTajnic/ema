# Copy this file to .env and fill in your values
# Never commit .env to version control

# Your MojeElektro API key (generated in the MojeElektro portal)
MOJELEKTRO_API_KEY=your_api_key_here

# API environment: "test" or "production"
MOJELEKTRO_ENV=test

# Port for the local web server
PORT=3000

# Oracle 26ai Database (EMAPDB)
ORACLE_USER=EMA_APP
ORACLE_PASSWORD=your_db_password_here
ORACLE_CONNECT_STRING=localhost:1521/emapdb
